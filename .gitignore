# ── Node / Vite build ────────────────────────────────────────
node_modules
dist
dist-ssr
.vite

# ── Local-only scratch (landing drafts, VPS scripts, notes) ──
# Matches both files ending in `.local` and the `.local/` directory.
*.local
.local/

# ── Editor / IDE ─────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Tauri ────────────────────────────────────────────────────
src-tauri/target
src-tauri/gen
# WiX fragment is machine-specific (absolute paths) — regenerated by
# `npm run wix-file-icons` (auto-run via beforeBuildCommand on every
# `tauri build`).
src-tauri/wix/file-icons.wxs
# Bundled sidecar binaries — fetched at build time, never committed
src-tauri/binaries
# Pandoc --extract-media artifact from manual imports
src-tauri/media

# ── Release notes staged for `gh release --notes-file` ──────
# Regenerated per version; content lives in the GitHub Release body.
.release-notes-*.md

# ── Python scratch (stray helpers aren't part of the build) ─
*.py
__pycache__/
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ── Zips / archives / packages at repo root ─────────────────
# Binary bundles (brand exports, design zips) belong in releases,
# not in source control.
/*.zip
/*.tar
/*.tar.gz
/*.7z

# ── Generic scratch ─────────────────────────────────────────
New folder/
*.bak
*.tmp

# ── OS crud ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
